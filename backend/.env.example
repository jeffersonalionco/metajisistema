# Banco principal (receitas / industc, industd, produtos)
PGHOST=localhost
PGPORT=5432
PGDATABASE=receitas
PGUSER=postgres
PGPASSWORD=sua_senha

# Banco de usuários (metajireceitas)
METAJI_HOST=localhost
METAJI_PORT=5432
METAJI_DATABASE=metajireceitas
METAJI_USER=postgres
METAJI_PASSWORD=sua_senha

# Autenticação JWT (troque em produção)
JWT_SECRET=chave-secreta-trocar-em-producao
JWT_EXPIRES=7d

# IA (Gemini) - usado para análise automática de relatórios Excel
# Coloque aqui a sua chave de API do Gemini.
# Exemplo de obtenção: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui
# Modelo Gemini (opcional). Exemplos: gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-1.5-flash
# Configuracao inicial opcional da IA de Documentacao (admin pode alterar no painel)
# GEMINI_DOC_MODEL=gemini-1.5-flash

PORT=3001
NODE_ENV=development
